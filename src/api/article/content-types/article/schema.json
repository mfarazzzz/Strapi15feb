{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "News Article",
    "description": "Standard news articles with breaking and featured flags."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "content-manager": {
      "visible": true
    }
  },
  "indexes": [
    { "name": "articles_slug_idx", "columns": ["slug"] },
    { "name": "articles_publishedAt_idx", "columns": ["published_at"] },
    { "name": "articles_views_idx", "columns": ["views"] }
  ],
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 200
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "unique": true,
      "pluginOptions": {
        "content-manager": { "editable": true }
      }
    },
    "short_headline": {
      "type": "string",
      "required": true,
      "maxLength": 110
    },
    "excerpt": {
      "type": "text",
      "required": true
    },
    "workflowStatus": {
      "type": "enumeration",
      "enum": ["draft", "submitted", "approved", "rejected"],
      "default": "draft"
    },
    "news_category": {
      "type": "enumeration",
      "enum": ["Local", "State", "National", "Politics", "Crime", "Education", "Sports", "Business"],
      "required": true
    },
    "content": {
      "type": "richtext",
      "required": true
    },
    "featured_image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "articles",
      "required": true
    },
    "author": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::author.author",
      "inversedBy": "articles",
      "required": true
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag",
      "inversedBy": "articles"
    },
    "location": {
      "type": "string"
    },
    "focus_keyword": {
      "type": "string"
    },
    "contentType": {
      "type": "enumeration",
      "enum": ["news", "editorial", "review", "interview", "opinion", "special-report"],
      "default": "news"
    },
    "workflowNote": {
      "type": "text"
    },
    "meta_description": {
      "type": "string",
      "required": true,
      "maxLength": 160
    },
    "seoTitle": {
      "type": "string",
      "maxLength": 70
    },
    "canonicalUrl": {
      "type": "string"
    },
    "ogTitle": {
      "type": "string",
      "maxLength": 70
    },
    "ogDescription": {
      "type": "string",
      "maxLength": 200
    },
    "ogImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "newsKeywords": {
      "type": "text"
    },
    "isBreaking": {
      "type": "boolean",
      "default": false
    },
    "isFeatured": {
      "type": "boolean",
      "default": false
    },
    "isEditorsPick": {
      "type": "boolean",
      "default": false
    },
    "discoverEligible": {
      "type": "boolean",
      "default": false
    },
    "heroPriority": {
      "type": "integer"
    },
    "videoType": {
      "type": "enumeration",
      "enum": ["none", "youtube", "local"],
      "default": "none"
    },
    "videoUrl": {
      "type": "string"
    },
    "videoTitle": {
      "type": "string"
    },
    "readTime": {
      "type": "string",
      "maxLength": 30
    },
    "views": {
      "type": "integer",
      "default": 0,
      "pluginOptions": {
        "content-manager": { "visible": false }
      }
    },
    "shares": {
      "type": "integer",
      "default": 0,
      "pluginOptions": {
        "content-manager": { "visible": false }
      }
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category",
      "pluginOptions": {
        "content-manager": { "visible": false }
      }
    },
    "seoShortTailKeywords": {
      "type": "json",
      "pluginOptions": {
        "content-manager": { "visible": false }
      }
    },
    "seoLongTailKeywords": {
      "type": "json",
      "pluginOptions": {
        "content-manager": { "visible": false }
      }
    },
    "seoKeywordsJson": {
      "type": "json",
      "pluginOptions": {
        "content-manager": { "visible": false }
      }
    },
    "schemaJson": {
      "type": "json",
      "pluginOptions": {
        "content-manager": { "visible": false }
      }
    }
  }
}
