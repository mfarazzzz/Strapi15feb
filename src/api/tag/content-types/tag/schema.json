{
  "kind": "collectionType",
  "collectionName": "tags",
  "info": {
    "singularName": "tag",
    "pluralName": "tags",
    "displayName": "Tag"
  },
  "options": {
    "draftAndPublish": false
  },
  "indexes": [
    { "name": "tags_slug_idx", "columns": ["slug"] },
    { "name": "tags_score_idx", "columns": ["score"] },
    { "name": "tags_recent_article_count_idx", "columns": ["recent_article_count"] }
  ],
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true,
      "maxLength": 80
    },
    "nameHindi": {
      "type": "string",
      "maxLength": 80
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true,
      "unique": true
    },
    "articleCount": {
      "type": "integer",
      "default": 0,
      "pluginOptions": { "content-manager": { "visible": true } }
    },
    "noindex": {
      "type": "boolean",
      "default": true,
      "pluginOptions": { "content-manager": { "visible": true } }
    },
    "canonicalTagId": {
      "type": "integer",
      "pluginOptions": { "content-manager": { "visible": true } }
    },
    "tagType": {
      "type": "enumeration",
      "enum": ["primary", "secondary", "derived"],
      "default": "secondary",
      "pluginOptions": { "content-manager": { "visible": true } }
    },
    "score": {
      "type": "integer",
      "default": 50,
      "pluginOptions": { "content-manager": { "visible": true } }
    },
    "recentArticleCount": {
      "type": "integer",
      "default": 0,
      "pluginOptions": { "content-manager": { "visible": true } }
    },
    "articles": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::article.article",
      "mappedBy": "tags"
    }
  }
}
