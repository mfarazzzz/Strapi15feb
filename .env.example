NODE_ENV=development
HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified
STRAPI_PUBLIC_URL=
STRAPI_PROXY=
SERVE_ADMIN_PANEL=true
ALLOW_PUBLIC_REGISTRATION=false
STRAPI_SEED=false
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db
DATABASE_URL=
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=
DATABASE_SCHEMA=public
DATABASE_SSL=false
DATABASE_SSL_KEY=
DATABASE_SSL_CERT=
DATABASE_SSL_CA=
DATABASE_SSL_CAPATH=
DATABASE_SSL_CIPHER=
DATABASE_SSL_REJECT_UNAUTHORIZED=true
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT=60000
CORS_ORIGINS=
CORS_HEADERS=Content-Type,Authorization,Origin,Accept
SLOW_REQUEST_THRESHOLD_MS=1000
RATE_LIMIT_INTERVAL=60000
RATE_LIMIT_MAX=200
FORM_LIMIT=50mb
JSON_LIMIT=50mb
TEXT_LIMIT=50mb
UPLOAD_SIZE_LIMIT=52428800

# ============================================================================
# REDIS CACHE
# ============================================================================
# Redis connection string — leave blank to disable caching
REDIS_URL=redis://localhost:6379
# Set to false to disable Redis cache without removing the URL
REDIS_CACHE_ENABLED=true
# Cache TTL in seconds (default 60)
REDIS_CACHE_TTL=60
# Key prefix for namespacing (avoids collisions if Redis is shared)
REDIS_CACHE_PREFIX=strapi-cache

# ============================================================================
# RATE LIMITING
# ============================================================================
# Interval in ms for rate limit window (default 60000 = 1 minute)
RATE_LIMIT_INTERVAL=60000
# Max requests per interval per IP (default 200)
RATE_LIMIT_MAX=200

# ============================================================================
# FRONTEND INTEGRATION
# ============================================================================
# Base URL of the public-facing frontend (used for revalidation calls)
SITE_URL=https://rampurnews.com
# Shared secret for ISR revalidation — must match REVALIDATE_SECRET in Frontend and CMS .env
REVALIDATE_SECRET=your-revalidate-secret-here

# ============================================================================
# PREVIEW MODE
# ============================================================================
# Secret token for draft preview — must match PREVIEW_SECRET in Frontend .env
PREVIEW_SECRET=your-preview-secret-here

# ============================================================================
# ADMIN PANEL
# ============================================================================
# Set to false to disable the Strapi admin panel (recommended in production)
SERVE_ADMIN_PANEL=true
# Comma-separated list of super-admin emails to auto-assign on bootstrap
ADMIN_PANEL_SUPER_ADMIN_EMAILS=
